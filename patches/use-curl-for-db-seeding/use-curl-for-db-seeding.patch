From 166a089e29e266a575de849530ebcd0dabac8c92 Mon Sep 17 00:00:00 2001
From: Bargraph6 <193206525+Bargraph6@users.noreply.github.com>
Date: Tue, 14 Apr 2026 16:46:42 +0700
Subject: [PATCH] use curl for db seeding

---
 lib/tasks/db/import.rake | 5 +----
 1 file changed, 1 insertion(+), 4 deletions(-)

diff --git a/lib/tasks/db/import.rake b/lib/tasks/db/import.rake
index ae77ee34..3f22db83 100644
--- a/lib/tasks/db/import.rake
+++ b/lib/tasks/db/import.rake
@@ -13,10 +13,7 @@ namespace :db do
       url = 'https://crimethinc-production.s3.us-west-2.amazonaws.com/database-dumps/crimethinc_production_db_dump.sql'
 
       puts '==> Downloading remote production DB dump from S3…'
-      File.open('database-dumps/crimethinc_production_db_dump.sql', 'wb') do |file|
-        # TODO: use Down or HTTP.rb gem instead
-        file << URI.open(url).read # rubocop:disable Security/Open
-      end
+      `curl --progress-bar -o 'database-dumps/crimethinc_production_db_dump.sql' #{url}`
     end
 
     desc 'Import pg dump into local development DB'
-- 
